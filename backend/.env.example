DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/merge
REDIS_URL=redis://default:PASSWORD@HOST:6379/0
SECRET_KEY=replace-with-a-long-random-secret
FRONTEND_URL=https://merge-frontend.vercel.app
DEBUG=false
MAX_PLAYLIST_LINKS=5
LIKED_SONGS_LIMIT=5000
TOTAL_TRACKS_LIMIT=50
MAX_TRACKS_PER_SECTION=20
YTMUSIC_RETRY_ATTEMPTS=3
# Google OAuth for YouTube Music (get from console.cloud.google.com)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-rotated-secret
YOUTUBE_OAUTH_REDIRECT_URI=https://your-backend.railway.app/auth/youtube/callback
# Feedback boost deltas (optional — these are the defaults)
FEEDBACK_LIKE_BOOST=10.0
FEEDBACK_DISLIKE_PENALTY=10.0
FEEDBACK_SKIP_PENALTY=5.0
